# Timezone for cron scheduling
TZ=America/New_York

# uid/gid of the host user that owns ./data - the entrypoint remaps the
# container user to these at startup so the bind-mounted tokens are readable
# (find yours with: id -u / id -g)
HOST_UID=1000
HOST_GID=1000

# Roborock account email
ROBOROCK_EMAIL=you@example.com

# Auth tokens come from the bind-mounted cache directory (./data by default).
# Generate them locally before starting the container:
#   ROBOROCK_CACHE_DIR=./data ./roborock.py login
